{
    "name": "firehed/php-lsp",
    "description": "A minimal, performant Language Server Protocol server for PHP",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Eric Stern",
            "email": "eric@ericstern.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "amphp/amp": "^3.0",
        "amphp/byte-stream": "^2.0",
        "nikic/php-parser": "^5.7"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^12.5.22",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Firehed\\PhpLsp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-0": {
            "Psr0": "tests/Fixtures/Autoload/"
        },
        "psr-4": {
            "Firehed\\PhpLsp\\Tests\\": "tests/"
        },
        "classmap": [
            "tests/Fixtures/Autoload/Classmap/"
        ]
    },
    "scripts": {
        "phpcs": "phpcs",
        "phpunit": "phpunit",
        "phpstan": "phpstan analyze",
        "check": [
            "@phpstan",
            "@phpunit",
            "@phpcs"
        ]
    },
    "bin": [
        "bin/php-lsp"
    ],
    "config": {
        "sort-packages": true
    }
}
