<?xml version="1.0"?>
<ruleset name="php-lsp">
    <description>Coding standard for php-lsp</description>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <rule ref="PSR12"/>

    <file>bin/</file>
    <file>src/</file>
    <file>tests/</file>
</ruleset>
